# ═══════════════════════════════════════════════════
#  RPi Market Notifier — Configuration
# ═══════════════════════════════════════════════════

# ─── Notification Channels ───
CHANNEL_TELEGRAM=true
CHANNEL_EMAIL=true

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Email (Gmail with App Password) ───
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECEIVER=you@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ─── APIs (leave blank to skip a source) ───
MMI_API=https://api.tickertape.in/mmi/now
QUOTES_API=https://quotes-api.tickertape.in/quotes

# IPO with GMP data (InvestorGain)
IPO_API=https://webnodejs.investorgain.com/cloud/new/report/data-read/331/1/2/{year}/{fy}/0/all?search=&v=20-18
# Old Chittorgarh IPO API (replaced by InvestorGain above)
#IPO_API=https://webnodejs.chittorgarh.com/cloud/report/data-read/82/1/2/{year}/{fy}/0/all/0?search=&v=11-00

# NCD IPO (GoldenPi)
NCD_IPO_API=https://api.goldenpi.com/v0/bonds/ipo-instruments
NCD_IPO_TOKEN=7353deac-af2a-4454-8f08-35347693e7b0

# Secondary Bond Market (GoldenPi)
SECONDARY_BONDS_API=https://api.goldenpi.com/v0/bonds/list
SECONDARY_BONDS_TOKEN=7353deac-af2a-4454-8f08-35347693e7b0

# Old Chittorgarh NCD API (replaced by GoldenPi above)
#NCD_API=https://webnodejs.chittorgarh.com/cloud/report/data-read/27/1/2/{year}/{fy}/0/0/0?search=&v=15-00

# ─── Tickers ───
TICKERS=RELI:Reliance Industries,TCS:TCS,INFY:Infosys,HDBK:HDFC Bank,ITC:ITC,NSEN:Nestle India

# ─── Schedule ───
NOTIFY_HOUR=18
NOTIFY_MINUTE=0
TIMEZONE=Asia/Kolkata

# ─── Heartbeat ───
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_HOURS=1
