# ═══════════════════════════════════════════════════
#  RPi Market Notifier — Configuration
# ═══════════════════════════════════════════════════

# ─── Notification Channels ───
# Toggle which channels to send reports through (true/false)
CHANNEL_TELEGRAM=true
CHANNEL_EMAIL=true

# ─── Telegram Bot ───
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Email (Gmail with App Password) ───
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail"
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECEIVER=you@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ─── APIs ───
# All API endpoints — leave blank to skip that data source
MMI_API=
QUOTES_API=
IPO_API=

# ─── Tickers ───
# Comma-separated list of TickerTape SIDs to track
# Format: SID:Display Name  (or just SID)
# Find SIDs from tickertape.in stock URLs:
#   https://www.tickertape.in/stocks/reliance-industries-RELI → SID = RELI
# Only tickers listed here will appear in notifications.
TICKERS=RELI:Reliance Industries,TCS:TCS,INFY:Infosys,HDBK:HDFC Bank,ITC:ITC,NSEN:Nestle India

# ─── Schedule ───
NOTIFY_HOUR=18
NOTIFY_MINUTE=0
TIMEZONE=Asia/Kolkata

# ─── Heartbeat ───
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_HOURS=1
